{
  "name": "mk-portfolio",
  "version": "3.0.0",
  "description": "Mohammed Karim personal portfolio \u2014 Data Analyst, Web Developer, Content Creator. Live at mkinsight.pages.dev",
  "author": "Mohammed Karim <mohammedkarim@outlook.com>",
  "license": "MIT",
  "homepage": "https://mkinsight.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mohammedkarim-MK/mk-portfolio.git"
  },
  "scripts": {
    "lint": "eslint assets/js/*.js --fix",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "validate": "html-validate index.html about.html contact.html MK-AI.html",
    "dev": "live-server --port=3000 --open=index.html",
    "start": "live-server --port=3000",
    "build": "echo 'Static site \u2014 no build step required'",
    "precommit": "npm run lint && npm run format",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "html-validate": "^8.18.0",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "portfolio",
    "data-analyst",
    "web-developer",
    "javascript",
    "ai",
    "groq",
    "netlify"
  ],
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "netlify/functions/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}